# MongoDB
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@<cluster>.mongodb.net/<dbname>

# Scraper source URLs
SITE1=                  # AutoAds Jamaica RSS feed URL
SITE2=                  # JaCars listing page URL
SITE3=                  # Jamaica Classified Online listing page URL
SITE4=                  # KMS listing page URL

# Email alerts (nodemailer SMTP)
AUTH_HOST=              # e.g. smtp.gmail.com
AUTH_PORT=465           # 465 for SSL, 587 for TLS
AUTH_USER=              # your email address
AUTH_PASS=              # your email password or app password
FROM_EMAIL=             # sender address
TO_EMAIL=               # where alerts are delivered

# App
PORT=3001
NODE_ENV=development

# Session & Auth
SESSION_SECRET=dev-secret-change-in-prod
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Puppeteer (required for jacars + jamaicaonlineclassifieds scrapers)
# Set ENABLE_PUPPETEER=true in your local .env to enable these scrapers in dev.
# Without this they are skipped every cron tick (intentional — saves memory on Heroku Basic).
ENABLE_PUPPETEER=true
# Path to Chrome binary. Leave blank to use Puppeteer's bundled Chromium (~150 MB auto-download).
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux:   /usr/bin/google-chrome
PUPPETEER_EXECUTABLE_PATH=
GOOGLE_CHROME_BIN=
